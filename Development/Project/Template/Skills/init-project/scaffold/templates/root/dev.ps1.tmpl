# dev.ps1 — 一鍵啟動 backend + frontend dev server(Windows / PowerShell)
#
# 用法:
#   .\dev.ps1                # 偵測舊 process → kill → 重啟 backend + frontend
#   .\dev.ps1 -SkipKill      # 不 kill 舊的(若 port 被占會失敗)
#
# 行為:
#   1. 確認 cwd 是 scaffold 出來的專案(有 backend/pyproject.toml + frontend/package.json)
#   2. 偵測 :{{backend_port}} 與 :{{frontend_port}} 是否被占用 → kill 占用者
#   3. 各自開新 PowerShell 視窗跑 uvicorn / vite,獨立 stdout 方便除錯
#   4. 印出網址與停止方式

[CmdletBinding()]
param(
    [switch]$SkipKill
)

$ErrorActionPreference = 'Stop'

$BackendPort  = {{backend_port}}
$FrontendPort = {{frontend_port}}

# ─── 1. cwd 健全性 ──────────────────────────────────────────────

if (-not (Test-Path 'backend\pyproject.toml')) {
    Write-Host '✗ 找不到 backend\pyproject.toml — 請在專案根目錄(scaffold 出來的位置)跑此腳本' -ForegroundColor Red
    exit 1
}
if (-not (Test-Path 'frontend\package.json')) {
    Write-Host '✗ 找不到 frontend\package.json — 請在專案根目錄跑此腳本' -ForegroundColor Red
    exit 1
}

# ─── 2. port 占用偵測 + kill ────────────────────────────────────

function Stop-PortListener {
    param([int]$Port, [string]$Label)
    $conns = Get-NetTCPConnection -LocalPort $Port -State Listen -ErrorAction SilentlyContinue
    if (-not $conns) {
        Write-Host "  · :$Port($Label)未被占用" -ForegroundColor DarkGray
        return
    }
    $pids = $conns | Select-Object -ExpandProperty OwningProcess -Unique
    foreach ($procId in $pids) {
        $proc = Get-Process -Id $procId -ErrorAction SilentlyContinue
        if ($proc) {
            Write-Host "  → kill PID $procId($($proc.ProcessName))占用 :$Port($Label)" -ForegroundColor Yellow
            Stop-Process -Id $procId -Force -ErrorAction SilentlyContinue
        }
    }
}

if ($SkipKill) {
    Write-Host '→ -SkipKill 啟用,略過 port 占用 kill' -ForegroundColor DarkGray
} else {
    Write-Host '→ 偵測 port 占用'
    Stop-PortListener -Port $BackendPort  -Label 'backend'
    Stop-PortListener -Port $FrontendPort -Label 'frontend'
    Start-Sleep -Milliseconds 500
}

# ─── 3. 啟動 backend + frontend(各自獨立視窗)───────────────────

Write-Host ''
Write-Host "→ 啟動 backend(uvicorn :$BackendPort)" -ForegroundColor Cyan
$backend = Start-Process powershell -ArgumentList @(
    '-NoExit',
    '-Command',
    "Set-Location '$PWD\backend'; uv run uvicorn app.main:app --reload --port $BackendPort --host 0.0.0.0"
) -PassThru

Write-Host "→ 啟動 frontend(vite :$FrontendPort)" -ForegroundColor Cyan
$frontend = Start-Process powershell -ArgumentList @(
    '-NoExit',
    '-Command',
    "Set-Location '$PWD\frontend'; npm run dev"
) -PassThru

# ─── 4. 提示 ────────────────────────────────────────────────────

Write-Host ''
Write-Host '✓ 已啟動' -ForegroundColor Green
Write-Host "  Backend  : http://localhost:$BackendPort/api/docs(PID $($backend.Id))"
Write-Host "  Frontend : http://localhost:$FrontendPort           (PID $($frontend.Id))"
Write-Host ''
Write-Host '停止方式(任一):' -ForegroundColor DarkGray
Write-Host '  · 跑 .\stop.ps1'
Write-Host '  · 重新跑 .\dev.ps1(會自動 kill 舊的再開)'
Write-Host '  · 直接關掉那兩個 PowerShell 視窗'
