#!/usr/bin/env bash
# stop.sh вҖ” еҒңжӯў backend + frontend dev server(macOS / Linux)
#
# з”Ёжі•:./stop.sh
# иЎҢзӮә:kill еҚ з”Ё :{{backend_port}} иҲҮ :{{frontend_port}} зҡ„ process

set -e

BACKEND_PORT={{backend_port}}
FRONTEND_PORT={{frontend_port}}

kill_port_listener() {
    local port=$1
    local label=$2
    local pids
    if command -v lsof >/dev/null 2>&1; then
        pids=$(lsof -ti tcp:"$port" -sTCP:LISTEN 2>/dev/null || true)
    elif command -v fuser >/dev/null 2>&1; then
        pids=$(fuser -n tcp "$port" 2>/dev/null | tr -d ':/tcp' || true)
    else
        echo "  ! зі»зөұз„Ў lsof / fuser,з„Ўжі•еҒөжё¬ :$port еҚ з”Ё"
        return
    fi
    if [ -z "$pids" ]; then
        echo "  В· :$port($label)жІ’жңү process еңЁи·‘"
        return
    fi
    for pid in $pids; do
        local pname
        pname=$(ps -p "$pid" -o comm= 2>/dev/null || echo unknown)
        echo "  вҶ’ kill PID $pid($pname)еҚ з”Ё :$port($label)"
        kill -9 "$pid" 2>/dev/null || true
    done
}

echo "вҶ’ еҒңжӯў dev server"
kill_port_listener "$BACKEND_PORT" backend
kill_port_listener "$FRONTEND_PORT" frontend
echo "вң“ е®ҢжҲҗ"
