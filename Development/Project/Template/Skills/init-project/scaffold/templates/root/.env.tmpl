# 本檔由 /init-project skill 自動產生(不會被 git 追蹤,見 .gitignore)
# 內含使用者輸入的 PostgreSQL 連線資訊;如需修改,直接編輯本檔即可
# 部署到 staging / production 時,請另外建立 .env.staging / .env.production,**禁**直接 cp 本檔

APP_ENV=development
POSTGRES_VERSION={{postgres_version}}
DATABASE_URL=postgresql+asyncpg://{{postgres_user}}:{{postgres_password}}@localhost:{{postgres_port}}/{{project_name_underscore}}
JWT_SECRET_KEY=changeme-32-bytes-very-very-secret
CORS_ORIGINS=["http://localhost:{{frontend_port}}"]
