#!/usr/bin/env bash
# dev.sh — 一鍵啟動 backend + frontend dev server(macOS / Linux)
#
# 用法:
#   ./dev.sh                # 偵測舊 process → kill → 重啟 backend + frontend
#   ./dev.sh --skip-kill    # 不 kill 舊的(若 port 被占會失敗)
#
# 行為:
#   1. 確認 cwd 是 scaffold 出來的專案(有 backend/pyproject.toml + frontend/package.json)
#   2. 偵測 :{{backend_port}} 與 :{{frontend_port}} 是否被占用 → kill 占用者
#   3. 兩個 dev server 都背景跑,Ctrl+C 一次全停
#   4. 印出網址

set -e

BACKEND_PORT={{backend_port}}
FRONTEND_PORT={{frontend_port}}
SKIP_KILL=0

for arg in "$@"; do
    case "$arg" in
        --skip-kill) SKIP_KILL=1 ;;
        *) echo "未知參數:$arg"; exit 1 ;;
    esac
done

# ─── 1. cwd 健全性 ──────────────────────────────────────────────

if [ ! -f backend/pyproject.toml ]; then
    echo "✗ 找不到 backend/pyproject.toml — 請在專案根目錄(scaffold 出來的位置)跑此腳本"
    exit 1
fi
if [ ! -f frontend/package.json ]; then
    echo "✗ 找不到 frontend/package.json — 請在專案根目錄跑此腳本"
    exit 1
fi

# ─── 2. port 占用偵測 + kill ────────────────────────────────────

kill_port_listener() {
    local port=$1
    local label=$2
    local pids
    if command -v lsof >/dev/null 2>&1; then
        pids=$(lsof -ti tcp:"$port" -sTCP:LISTEN 2>/dev/null || true)
    elif command -v fuser >/dev/null 2>&1; then
        pids=$(fuser -n tcp "$port" 2>/dev/null | tr -d ':/tcp' || true)
    else
        echo "  ! 系統無 lsof / fuser,無法偵測 :$port 占用 — 請自行確認"
        return
    fi
    if [ -z "$pids" ]; then
        echo "  · :$port($label)未被占用"
        return
    fi
    for pid in $pids; do
        local pname
        pname=$(ps -p "$pid" -o comm= 2>/dev/null || echo unknown)
        echo "  → kill PID $pid($pname)占用 :$port($label)"
        kill -9 "$pid" 2>/dev/null || true
    done
}

if [ "$SKIP_KILL" = "1" ]; then
    echo "→ --skip-kill 啟用,略過 port 占用 kill"
else
    echo "→ 偵測 port 占用"
    kill_port_listener "$BACKEND_PORT" backend
    kill_port_listener "$FRONTEND_PORT" frontend
    sleep 0.5
fi

# ─── 3. 啟動 backend + frontend ────────────────────────────────

echo ""
echo "→ 啟動 backend(uvicorn :$BACKEND_PORT)"
( cd backend && uv run uvicorn app.main:app --reload --port "$BACKEND_PORT" --host 0.0.0.0 ) &
BACKEND_PID=$!

echo "→ 啟動 frontend(vite :$FRONTEND_PORT)"
( cd frontend && npm run dev ) &
FRONTEND_PID=$!

cleanup() {
    echo ""
    echo "→ 收尾:停止 backend(PID $BACKEND_PID)+ frontend(PID $FRONTEND_PID)"
    kill "$BACKEND_PID" "$FRONTEND_PID" 2>/dev/null || true
    exit 0
}
trap cleanup INT TERM

# ─── 4. 提示 ────────────────────────────────────────────────────

echo ""
echo "✓ 已啟動"
echo "  Backend  : http://localhost:$BACKEND_PORT/api/docs(PID $BACKEND_PID)"
echo "  Frontend : http://localhost:$FRONTEND_PORT           (PID $FRONTEND_PID)"
echo ""
echo "停止方式(任一):"
echo "  · 在此終端按 Ctrl+C"
echo "  · 開另一個終端跑 ./stop.sh"
echo "  · 重新跑 ./dev.sh(會自動 kill 舊的再開)"

wait
