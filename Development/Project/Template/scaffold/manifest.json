{
  "$comment": "scaffold manifest — 唯一真相來源(版本 / 檔案地圖 / 條件分支)。改版本只改本檔,template 內用 {{var}} 引用。",
  "schema_version": "1.0",

  "versions": {
    "python": "3.14.1",
    "node": "24.0.0",
    "postgres": "18",
    "frontend": {
      "react": "19.2.5",
      "react_dom": "19.2.5",
      "redux_toolkit": "2.11.2",
      "react_redux": "9.2.0",
      "typescript": "5.9.3",
      "vite": "6.0.7",
      "vite_plugin_react": "4.3.4",
      "tailwindcss": "4.2.4",
      "tailwindcss_postcss": "4.2.4",
      "postcss": "8.5.12",
      "eslint": "9.39.4"
    },
    "backend": {
      "fastapi": "0.136.1",
      "uvicorn": "0.46.0",
      "sqlalchemy": "2.0.49",
      "asyncpg": "0.31.0",
      "pydantic": "2.13.3",
      "pydantic_settings": "2.14.0",
      "alembic": "1.14.0",
      "httpx": "0.28.1",
      "passlib_bcrypt": "1.7.4",
      "pyjwt_crypto": "2.10.1",
      "python_multipart": "0.0.20"
    }
  },

  "params": {
    "$comment": "param 預設值;CLI 可覆蓋",
    "project_name": { "required": true, "validate": "kebab-case" },
    "frontend": { "default": "vite", "enum": ["vite", "next"] },
    "include_azure_sso": { "default": false, "type": "boolean" },
    "frontend_port": { "default": 3000, "type": "number" },
    "backend_port": { "default": 8000, "type": "number" },
    "postgres_port": { "default": 5432, "type": "number" },
    "api_version": { "default": "v1" }
  },

  "actions": [
    { "$section": "always — root files" },
    { "type": "render", "src": "templates/root/.gitignore.tmpl",                "dst": ".gitignore" },
    { "type": "render", "src": "templates/root/.env.development.example.tmpl",  "dst": ".env.development.example" },
    { "type": "render", "src": "templates/root/.env.staging.example.tmpl",      "dst": ".env.staging.example" },
    { "type": "render", "src": "templates/root/.env.production.example.tmpl",   "dst": ".env.production.example" },
    { "type": "render", "src": "templates/root/README.md.tmpl",                 "dst": "README.md" },
    { "type": "copy",   "src": "../CLAUDE.md",                                  "dst": "CLAUDE.md" },
    { "type": "copy",   "src": "../AGENTS.md",                                  "dst": "AGENTS.md" },

    { "$section": "always — docs (verbatim from Template)" },
    { "type": "copy_dir", "src": "../docs/Design-Base", "dst": "docs/Design-Base" },
    { "type": "copy_dir", "src": "../docs/Arch",        "dst": "docs/Arch" },
    { "type": "render",   "src": "templates/docs/Tasks/v1.0.0/tasks-v1.0.0.md.tmpl", "dst": "docs/Tasks/v1.0.0/tasks-v1.0.0.md" },
    { "type": "mkdir",    "dst": "docs/Tasks/scan-project" },

    { "$section": "always — .claude/.github" },
    { "type": "copy",     "src": "../prompts/scan-project.md",                  "dst": ".claude/commands/scan-project.md" },
    { "type": "render",   "src": "templates/.github/workflows/ci.yml.tmpl",     "dst": ".github/workflows/ci.yml" },

    { "$section": "always — backend skeleton" },
    { "type": "render", "src": "templates/backend/pyproject.toml.tmpl",                "dst": "backend/pyproject.toml" },
    { "type": "render", "src": "templates/backend/alembic.ini.tmpl",                   "dst": "backend/alembic.ini" },
    { "type": "render", "src": "templates/backend/alembic/env.py.tmpl",                "dst": "backend/alembic/env.py" },
    { "type": "mkdir",  "dst": "backend/alembic/versions" },
    { "type": "render", "src": "templates/backend/app/main.py.tmpl",                   "dst": "backend/app/main.py" },
    { "type": "render", "src": "templates/backend/app/core/config.py.tmpl",            "dst": "backend/app/core/config.py" },
    { "type": "render", "src": "templates/backend/app/core/db.py.tmpl",                "dst": "backend/app/core/db.py" },
    { "type": "render", "src": "templates/backend/app/core/security.py.tmpl",          "dst": "backend/app/core/security.py" },
    { "type": "render", "src": "templates/backend/app/core/response.py.tmpl",          "dst": "backend/app/core/response.py" },
    { "type": "render", "src": "templates/backend/app/core/exceptions.py.tmpl",        "dst": "backend/app/core/exceptions.py" },
    { "type": "render", "src": "templates/backend/app/core/cookies.py.tmpl",           "dst": "backend/app/core/cookies.py" },
    { "type": "render", "src": "templates/backend/app/api/deps.py.tmpl",               "dst": "backend/app/api/deps.py" },
    { "type": "render", "src": "templates/backend/app/api/v1/__init__.py.tmpl",        "dst": "backend/app/api/v1/__init__.py" },
    { "type": "render", "src": "templates/backend/app/api/v1/health.py.tmpl",          "dst": "backend/app/api/v1/health.py" },
    { "type": "render", "src": "templates/backend/app/models/__init__.py.tmpl",        "dst": "backend/app/models/__init__.py" },
    { "type": "render", "src": "templates/backend/app/models/base.py.tmpl",            "dst": "backend/app/models/base.py" },
    { "type": "render", "src": "templates/backend/app/schemas/response.py.tmpl",       "dst": "backend/app/schemas/response.py" },
    { "type": "mkdir",  "dst": "backend/app/repositories" },
    { "type": "mkdir",  "dst": "backend/app/services" },
    { "type": "mkdir",  "dst": "backend/app/clients" },

    { "$section": "frontend — vite branch" },
    { "type": "render", "src": "templates/frontend-vite/package.json.tmpl",            "dst": "frontend/package.json",        "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/tsconfig.json.tmpl",           "dst": "frontend/tsconfig.json",       "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/vite.config.ts.tmpl",          "dst": "frontend/vite.config.ts",      "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/index.html.tmpl",              "dst": "frontend/index.html",          "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/.env.local.example.tmpl",      "dst": "frontend/.env.local.example",  "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/main.tsx.tmpl",            "dst": "frontend/src/main.tsx",        "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/App.tsx.tmpl",             "dst": "frontend/src/App.tsx",         "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/index.css.tmpl",           "dst": "frontend/src/index.css",       "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/lib/api/baseApi.ts.tmpl",  "dst": "frontend/src/lib/api/baseApi.ts", "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/store/store.ts.tmpl",      "dst": "frontend/src/store/store.ts",  "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/store/provider.tsx.tmpl",  "dst": "frontend/src/store/provider.tsx", "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/utils/datetime.ts.tmpl",   "dst": "frontend/src/utils/datetime.ts", "when": { "frontend": "vite" } },
    { "type": "mkdir",  "dst": "frontend/src/components", "when": { "frontend": "vite" } },

    { "$section": "frontend — next branch (placeholder, Phase 3)" },
    { "$todo": "next branch templates 待 Phase 3 補上",
      "type": "render", "src": "templates/frontend-next/package.json.tmpl",            "dst": "frontend/package.json",        "when": { "frontend": "next" } },

    { "$section": "optional — azure_ad SSO module" },
    { "type": "render", "src": "templates/backend/app/clients/azure_ad/__init__.py.tmpl", "dst": "backend/app/clients/azure_ad/__init__.py", "when": { "include_azure_sso": true } },
    { "type": "render", "src": "templates/backend/app/clients/azure_ad/client.py.tmpl",   "dst": "backend/app/clients/azure_ad/client.py",   "when": { "include_azure_sso": true } },
    { "type": "render", "src": "templates/backend/app/clients/azure_ad/schemas.py.tmpl",  "dst": "backend/app/clients/azure_ad/schemas.py",  "when": { "include_azure_sso": true } },
    { "type": "render", "src": "templates/backend/app/clients/azure_ad/errors.py.tmpl",   "dst": "backend/app/clients/azure_ad/errors.py",   "when": { "include_azure_sso": true } },
    { "type": "render", "src": "templates/backend/app/clients/azure_ad/README.md.tmpl",   "dst": "backend/app/clients/azure_ad/README.md",   "when": { "include_azure_sso": true } }
  ],

  "post_actions": [
    { "type": "shell", "cmd": "uv lock",     "cwd": "backend",  "label": "uv lock",     "skip_when_no_install": true },
    { "type": "shell", "cmd": "npm install", "cwd": "frontend", "label": "npm install", "skip_when_no_install": true }
  ]
}
