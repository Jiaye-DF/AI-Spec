[project]
name = "{{project_name}}-backend"
version = "0.1.0"
requires-python = "=={{python_version}}.*"
dependencies = [
    "fastapi=={{fastapi_version}}",
    "uvicorn[standard]=={{uvicorn_version}}",
    "pydantic=={{pydantic_version}}",
    "pydantic-settings=={{pydantic_settings_version}}",
    "httpx=={{httpx_version}}",
    "passlib[bcrypt]=={{passlib_bcrypt_version}}",
    "pyjwt[crypto]=={{pyjwt_crypto_version}}",
    "python-multipart=={{python_multipart_version}}",
{{#if include_database}}    "sqlalchemy[asyncio]=={{sqlalchemy_version}}",
    "asyncpg=={{asyncpg_version}}",
    "alembic=={{alembic_version}}",
{{/if}}]

[dependency-groups]
dev = [
    "ruff=={{ruff_version}}",
    "mypy=={{mypy_version}}",
    "pytest=={{pytest_version}}",
    "pip-audit=={{pip_audit_version}}",
]

[tool.uv]
package = false

[tool.ruff]
line-length = 100
target-version = "py314"
extend-exclude = ["alembic/versions"]

[tool.ruff.lint]
select = ["E", "F", "I", "B", "UP"]

[tool.mypy]
python_version = "3.14"
strict = true
exclude = ["alembic/versions"]

[[tool.mypy.overrides]]
module = ["passlib.*"]
ignore_missing_imports = true
