import { createApi, fetchBaseQuery } from '@reduxjs/toolkit/query/react'

export const baseApi = createApi({
  reducerPath: 'api',
  baseQuery: fetchBaseQuery({
    baseUrl: process.env.NEXT_PUBLIC_API_URL ?? 'http://localhost:{{backend_port}}/api/{{api_version}}',
    credentials: 'include',
  }),
  tagTypes: [],
  endpoints: () => ({}),
})
