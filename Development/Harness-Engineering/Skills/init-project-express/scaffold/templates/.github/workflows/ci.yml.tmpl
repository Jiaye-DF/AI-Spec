name: ci

on:
  pull_request:
    branches: [main]
  push:
    branches: [main]

permissions:
  contents: read

jobs:
  frontend-test:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ./frontend
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version-file: frontend/package.json
          cache: npm
          cache-dependency-path: frontend/package-lock.json
      - run: npm ci
      - run: npm run lint
      - run: npm run typecheck
      - run: npm run test -- --run
      - run: npm run build

  backend-test:
    runs-on: ubuntu-latest
    defaults:
      run:
        working-directory: ./backend
{{#if include_database}}    services:
      postgres:
        image: postgres:{{postgres_version}}
        env:
          POSTGRES_PASSWORD: ci-only
          POSTGRES_DB: ci_test
          TZ: Asia/Taipei
        ports: ["5432:5432"]
        options: >-
          --health-cmd pg_isready
          --health-interval 5s
          --health-timeout 5s
          --health-retries 10
    env:
      APP_ENV: development
      DATABASE_URL: postgresql://postgres:ci-only@localhost:5432/ci_test
      JWT_SECRET_KEY: ci-only-not-for-production
{{/if}}{{#if !include_database}}    env:
      APP_ENV: development
      JWT_SECRET_KEY: ci-only-not-for-production
{{/if}}    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version-file: backend/package.json
          cache: npm
          cache-dependency-path: backend/package-lock.json
      - run: npm ci
      - run: npm run lint
      - run: npm run typecheck
{{#if include_database}}      - run: npx prisma migrate deploy
{{/if}}      - run: npm test

  dependency-audit:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-node@v4
        with:
          node-version-file: frontend/package.json
          cache: npm
          cache-dependency-path: frontend/package-lock.json
      - name: npm audit (frontend)
        working-directory: ./frontend
        run: npm audit --audit-level=high
        continue-on-error: true
      - uses: actions/setup-node@v4
        with:
          node-version-file: backend/package.json
          cache: npm
          cache-dependency-path: backend/package-lock.json
      - name: npm audit (backend)
        working-directory: ./backend
        run: |
          npm ci
          npm audit --audit-level=high
        continue-on-error: true

  secret-scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0
      - uses: gitleaks/gitleaks-action@v2
        env:
          GITLEAKS_LICENSE: ${{ secrets.GITLEAKS_LICENSE }}
        with:
          config-path: .gitleaks.toml

  security-scan:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: returntocorp/semgrep-action@v1
        with:
          config: >-
            p/owasp-top-ten
            p/nodejs
            p/typescript
            p/react
            p/security-audit
