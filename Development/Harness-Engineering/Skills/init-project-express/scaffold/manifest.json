{
  "$comment": "scaffold manifest — 唯一真相來源(版本 / 檔案地圖 / 條件分支)。改版本只改本檔,template 內用 {{var}} 引用。dst 也支援 {{api_version}} 之類佔位。",
  "schema_version": "1.0",

  "versions": {
    "scaffold_version": "1.0",
    "node": "24.0.0",
    "postgres": "18",
    "docker": {
      "frontend_node_image": "node:24-alpine",
      "backend_node_image": "node:24-alpine",
      "postgres_image": "postgres:18-alpine"
    },
    "frontend": {
      "next": "16.2.7",
      "react": "19.2.0",
      "react_dom": "19.2.0",
      "redux_toolkit": "2.11.2",
      "react_redux": "9.2.0",
      "typescript": "5.9.3",
      "types_node": "24.0.0",
      "types_react": "19.1.6",
      "types_react_dom": "19.1.5",
      "tailwindcss": "4.2.4",
      "tailwindcss_postcss": "4.2.4",
      "postcss": "8.5.12",
      "eslint": "9.39.4",
      "eslint_config_next": "16.2.7",
      "eslint_eslintrc": "3.2.0",
      "eslint_js": "9.39.4",
      "typescript_eslint": "8.62.0",
      "vite": "6.0.7",
      "vite_plugin_react": "4.3.4",
      "vitest": "2.1.9"
    },
    "backend": {
      "express": "5.0.1",
      "cors": "2.8.5",
      "zod": "3.24.2",
      "bcryptjs": "2.4.3",
      "jsonwebtoken": "9.0.2",
      "cookie_parser": "1.4.7",
      "prisma": "6.2.1",
      "prisma_client": "6.2.1",
      "typescript": "5.9.3",
      "types_node": "24.0.0",
      "types_express": "5.0.3",
      "types_cors": "2.8.17",
      "types_bcryptjs": "2.4.6",
      "types_jsonwebtoken": "9.0.9",
      "types_cookie_parser": "1.4.8",
      "types_supertest": "6.0.2",
      "ts_node_dev": "2.0.0",
      "jest": "29.7.0",
      "types_jest": "29.5.12",
      "ts_jest": "29.2.5",
      "supertest": "7.0.0",
      "eslint": "9.39.4",
      "typescript_eslint": "8.62.0"
    }
  },

  "params": {
    "$comment": "param 預設值;CLI 可覆蓋。postgres_user / postgres_password 預設值由 scaffold.mjs buildPlaceholders() 計算(user=project_name_underscore;password=changeme-development);只在 include_database=true 時用",
    "project_name": { "required": true, "validate": "kebab-case" },
    "frontend": { "default": "next", "enum": ["next", "vite"] },
    "include_database": { "default": true, "type": "boolean" },
    "use_docker_compose": { "default": false, "type": "boolean", "$note": "由 SKILL.md § 1c Docker 偵測結果設定;true 時 scaffold 額外產 docker-compose.yml + Dockerfile" },
    "frontend_port": { "default": 3000, "type": "number" },
    "backend_port": { "default": 8000, "type": "number" },
    "postgres_port": { "default": 5432, "type": "number" },
    "postgres_user": { "default": null, "type": "string", "$note": "null = 由 scaffold.mjs 用 project_name_underscore 填入" },
    "postgres_password": { "default": "changeme-development", "type": "string" },
    "api_version": { "default": "v1" }
  },

  "actions": [
    { "$section": "always — root files" },
    { "type": "render", "src": "templates/root/CLAUDE.md.tmpl",                 "dst": "CLAUDE.md" },
    { "type": "render", "src": "templates/root/.gitignore.tmpl",                "dst": ".gitignore" },
    { "type": "render", "src": "templates/root/.env.development.example.tmpl",  "dst": ".env.development.example" },
    { "type": "render", "src": "templates/root/.env.staging.example.tmpl",      "dst": ".env.staging.example" },
    { "type": "render", "src": "templates/root/.env.production.example.tmpl",   "dst": ".env.production.example" },
    { "type": "render", "src": "templates/root/README.md.tmpl",                 "dst": "README.md" },
    { "type": "render", "src": "templates/root/.gitleaks.toml.tmpl",            "dst": ".gitleaks.toml" },

    { "$section": "always — .github workflows" },
    { "type": "render",   "src": "templates/.github/workflows/ci.yml.tmpl",     "dst": ".github/workflows/ci.yml" },
    { "type": "render",   "src": "templates/.github/workflows/e2e.yml.tmpl",    "dst": ".github/workflows/e2e.yml" },

    { "$section": "always — backend skeleton (Express + TypeScript)" },
    { "type": "render", "src": "templates/backend/package.json.tmpl",                        "dst": "backend/package.json" },
    { "type": "render", "src": "templates/backend/tsconfig.json.tmpl",                       "dst": "backend/tsconfig.json" },
    { "type": "render", "src": "templates/backend/jest.config.ts.tmpl",                      "dst": "backend/jest.config.ts" },
    { "type": "render", "src": "templates/backend/eslint.config.mjs.tmpl",                   "dst": "backend/eslint.config.mjs" },
    { "type": "render", "src": "templates/backend/src/server.ts.tmpl",                       "dst": "backend/src/server.ts" },
    { "type": "render", "src": "templates/backend/src/app.ts.tmpl",                          "dst": "backend/src/app.ts" },
    { "type": "render", "src": "templates/backend/src/config/index.ts.tmpl",                 "dst": "backend/src/config/index.ts" },
    { "type": "render", "src": "templates/backend/src/routes/v1/index.ts.tmpl",              "dst": "backend/src/routes/{{api_version}}/index.ts" },
    { "type": "render", "src": "templates/backend/src/routes/v1/health.ts.tmpl",             "dst": "backend/src/routes/{{api_version}}/health.ts" },
    { "type": "render", "src": "templates/backend/src/middleware/errors.ts.tmpl",            "dst": "backend/src/middleware/errors.ts" },
    { "type": "render", "src": "templates/backend/src/utils/response.ts.tmpl",               "dst": "backend/src/utils/response.ts" },
    { "type": "render", "src": "templates/backend/src/utils/security.ts.tmpl",               "dst": "backend/src/utils/security.ts" },
    { "type": "render", "src": "templates/backend/src/types/response.ts.tmpl",               "dst": "backend/src/types/response.ts" },
    { "type": "render", "src": "templates/_empty.tmpl",                                      "dst": "backend/src/services/.gitkeep" },
    { "type": "render", "src": "templates/_empty.tmpl",                                      "dst": "backend/src/clients/.gitkeep" },
    { "type": "render", "src": "templates/backend/tests/smoke.test.ts.tmpl",                 "dst": "backend/tests/smoke.test.ts" },

    { "$section": "database — .env (when include_database=true; gitignored)" },
    { "type": "render", "src": "templates/root/.env.tmpl",                                   "dst": ".env",                            "when": { "include_database": true } },

    { "$section": "backend — database (when include_database=true)" },
    { "type": "render", "src": "templates/backend/src/db.ts.tmpl",                           "dst": "backend/src/db.ts",               "when": { "include_database": true } },
    { "type": "render", "src": "templates/backend/prisma/schema.prisma.tmpl",                "dst": "backend/prisma/schema.prisma",    "when": { "include_database": true } },

    { "$section": "frontend — next branch (Next.js 16 App Router)" },
    { "type": "render", "src": "templates/frontend-next/package.json.tmpl",            "dst": "frontend/package.json",                            "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/tsconfig.json.tmpl",           "dst": "frontend/tsconfig.json",                           "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/next.config.ts.tmpl",          "dst": "frontend/next.config.ts",                          "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/postcss.config.mjs.tmpl",      "dst": "frontend/postcss.config.mjs",                      "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/eslint.config.mjs.tmpl",       "dst": "frontend/eslint.config.mjs",                       "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/.env.local.example.tmpl",      "dst": "frontend/.env.local.example",                      "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/app/layout.tsx.tmpl",      "dst": "frontend/src/app/layout.tsx",                      "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/app/page.tsx.tmpl",        "dst": "frontend/src/app/page.tsx",                        "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/app/globals.css.tmpl",     "dst": "frontend/src/app/globals.css",                     "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/lib/api/baseApi.ts.tmpl",  "dst": "frontend/src/lib/api/baseApi.ts",                   "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/store/store.ts.tmpl",      "dst": "frontend/src/store/store.ts",                      "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/store/provider.tsx.tmpl",  "dst": "frontend/src/store/provider.tsx",                   "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/utils/datetime.ts.tmpl",   "dst": "frontend/src/utils/datetime.ts",                   "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/vitest.config.ts.tmpl",  "dst": "frontend/vitest.config.ts",                                "when": { "frontend": "next" } },
    { "type": "render", "src": "templates/frontend-next/src/smoke.test.ts.tmpl","dst": "frontend/src/smoke.test.ts",                               "when": { "frontend": "next" } },
    { "type": "mkdir",  "dst": "frontend/public",                                                                                                  "when": { "frontend": "next" } },
    { "type": "mkdir",  "dst": "frontend/src/components",                                                                                          "when": { "frontend": "next" } },

    { "$section": "frontend — vite branch" },
    { "type": "render", "src": "templates/frontend-vite/package.json.tmpl",            "dst": "frontend/package.json",        "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/tsconfig.json.tmpl",           "dst": "frontend/tsconfig.json",       "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/vite.config.ts.tmpl",          "dst": "frontend/vite.config.ts",      "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/eslint.config.js.tmpl",        "dst": "frontend/eslint.config.js",    "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/index.html.tmpl",              "dst": "frontend/index.html",          "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/.env.local.example.tmpl",      "dst": "frontend/.env.local.example",  "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/main.tsx.tmpl",            "dst": "frontend/src/main.tsx",        "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/App.tsx.tmpl",             "dst": "frontend/src/App.tsx",         "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/index.css.tmpl",           "dst": "frontend/src/index.css",       "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/lib/api/baseApi.ts.tmpl",  "dst": "frontend/src/lib/api/baseApi.ts", "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/store/store.ts.tmpl",      "dst": "frontend/src/store/store.ts",  "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/store/provider.tsx.tmpl",  "dst": "frontend/src/store/provider.tsx", "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/utils/datetime.ts.tmpl",   "dst": "frontend/src/utils/datetime.ts", "when": { "frontend": "vite" } },
    { "type": "render", "src": "templates/frontend-vite/src/smoke.test.ts.tmpl",       "dst": "frontend/src/smoke.test.ts",     "when": { "frontend": "vite" } },
    { "type": "mkdir",  "dst": "frontend/src/components", "when": { "frontend": "vite" } },

    { "$section": "optional — Docker Compose (when use_docker_compose=true)" },
    { "type": "render", "src": "templates/docker/docker-compose.yml.tmpl",             "dst": "docker-compose.yml",                               "when": { "use_docker_compose": true } },
    { "type": "render", "src": "templates/docker/frontend/Dockerfile.tmpl",            "dst": "frontend/Dockerfile",                              "when": { "use_docker_compose": true } },
    { "type": "render", "src": "templates/docker/frontend/.dockerignore.tmpl",         "dst": "frontend/.dockerignore",                           "when": { "use_docker_compose": true } },
    { "type": "render", "src": "templates/docker/backend/Dockerfile.tmpl",             "dst": "backend/Dockerfile",                               "when": { "use_docker_compose": true } },
    { "type": "render", "src": "templates/docker/backend/.dockerignore.tmpl",          "dst": "backend/.dockerignore",                            "when": { "use_docker_compose": true } }
  ],

  "post_actions": [
    { "type": "shell", "cmd": "npm install", "cwd": "backend",  "label": "npm install (backend)",  "skip_when_no_install": true },
    { "type": "shell", "cmd": "npm install", "cwd": "frontend", "label": "npm install (frontend)", "skip_when_no_install": true },
    { "type": "shell", "cmd": "npx prisma generate", "cwd": "backend", "label": "prisma generate", "skip_when_no_install": true, "when": { "include_database": true } }
  ]
}
